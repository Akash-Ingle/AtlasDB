{
  "dashboard": {
    "id": null,
    "uid": "atlas-overview",
    "title": "AtlasDB - System Overview",
    "tags": ["atlasdb"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(atlas_http_requests_total[1m])) by (method, route)",
            "legendFormat": "{{method}} {{route}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Latency (p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(atlas_http_request_duration_seconds_bucket[5m])) by (le, route))",
            "legendFormat": "{{route}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Events Ingested (rate)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(atlas_events_ingested_total[1m])) by (source)",
            "legendFormat": "{{source}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Queue Depth",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(atlas_queue_depth)"
          }
        ]
      },
      {
        "id": 5,
        "title": "Processing Errors",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(atlas_processing_errors_total[5m]))"
          }
        ]
      },
      {
        "id": 6,
        "title": "Events Processed (rate)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(atlas_events_processed_total[1m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "id": 7,
        "title": "DB Query Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(atlas_db_query_duration_seconds_bucket[5m])) by (le, query))",
            "legendFormat": "{{query}}"
          }
        ]
      }
    ]
  }
}
