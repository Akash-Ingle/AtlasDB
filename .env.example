# AtlasDB Environment Configuration
# Copy to .env and adjust values for your environment

# ── Server ──────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlasdb
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=5

# ── Redis ───────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Authentication ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Ingestion ───────────────────────────────────────────────────────
INGEST_MAX_BATCH=1000
INGEST_NUM_PARTITIONS=4
INGEST_QUEUE_BACKPRESSURE=100000

# ── Processor ───────────────────────────────────────────────────────
PROCESSOR_WORKERS=4
PROCESSOR_BATCH_SIZE=100
PROCESSOR_CONSUMER_GROUP=atlas-processors

# ── AI Layer ──────────────────────────────────────────────────────
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
EMBED_MODEL=text-embedding-3-small

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
